import { getFuncionario } from "./FuncionarioService"

const URL = `${import.meta.env.VITE_BASE_API_URL}/justificativa`



const criarJustificativa = async (idUser, dataEntrada,
    dataSaida, motivo, token) => {
    try {        

        const resp = await fetch(URL,{ method: 'POST',
            headers:{
                'Content-Type': 'application/json',
                'Authorization': 'Bearer '+token
            },
            body:JSON.stringify({
                "idUser": idUser,
                "dataEntrada": dataEntrada.toISOString(),
                "dataSaida": dataSaida.toISOString(),
                "motivo": motivo,
                "status": "AGUARDANDO"
            }) 
        })

        return true
    } catch (e) {
        return false
    }
}

const getAllJustificativas = async (user) =>{
    try {
        const resp = await fetch(URL)
        const data = await resp.json()
        const newData = await Promise.all(data.map( async j => {
            const n = await getFuncionario(j.idUser)
            return {...j, nomeUser:  n.nome }
        }))
        console.log(newData)
        if (user.ROLE === 'ADMIN'){
            return newData
        }else{
            return newData.filter( j => j.idUser === user.id)
        }

    } catch (e) {
        return 0
    }
}

const atualizaStatusJustificativa = async (idJustificativa, status, token) => {
    try {
        const resp = await fetch(`${URL}/${idJustificativa}`,{ method: 'PATCH',
            headers:{
                'Content-Type': 'application/json',
                'Authorization': 'Bearer '+token
            },
            body:JSON.stringify({
                "status": status
            }) 
        })
        return true
    } catch (e) {
        return false
    }
}

export { criarJustificativa, getAllJustificativas, atualizaStatusJustificativa }
