const URL = "http://localhost:3001/justificativa"


const criarJustificativa = async (idUser, dataEntrada,
    dataSaida, motivo, token) => {
    try {        

        const resp = await fetch(URL,{ method: 'POST',
            headers:{
                'Content-Type': 'application/json',
                'Authorization': 'Bearer '+token
            },
            body:JSON.stringify({
                "idUser": idUser,
                "dataEntrada": dataEntrada.toISOString(),
                "dataSaida": dataSaida.toISOString(),
                "motivo": motivo,
                "status": "AGUARDANDO"
            }) 
        })

        return true
    } catch (e) {
        return false
    }
}

const getAllJustificativas = async (user) =>{
    try {
        const resp = await fetch(URL)
        const data = await resp.json()
        if (user.ROLE === 'ADMIN'){
            return data
        }else{
            return data.filter( j => j.idUser === user.id)
        }

    } catch (e) {
        return 0
    }
}

export { criarJustificativa, getAllJustificativas }
